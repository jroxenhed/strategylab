#!/bin/sh
# Auto-stamp new TODO items + sync index before commit.
# Installed via: bin/install-hooks.sh

set -e

# Only run if TODO.md is staged
if git diff --cached --name-only | grep -qx 'TODO.md'; then
    if [ ! -f bin/sync-todo-index.py ]; then
        echo "pre-commit: bin/sync-todo-index.py missing, skipping sync"
        exit 0
    fi

    # --- Date-stamp newly-added top-level TODO items ---
    today=$(date +%Y-%m-%d)

    # IDs already present in the prior committed file (empty string on initial commit)
    prior_ids=$(git show HEAD:TODO.md 2>/dev/null \
        | grep -oE '^\- \[[ x]\] \*\*[A-Z]+[0-9]+[a-z]?\*\*' \
        | grep -oE '[A-Z]+[0-9]+[a-z]?' || true)

    # Top-level bullet lines that appear as additions in the staged diff
    new_lines=$(git diff --cached --unified=0 -- TODO.md \
        | grep '^+' | grep -v '^+++' \
        | sed 's/^+//' \
        | grep -E '^\- \[[ x]\] \*\*[A-Z]+[0-9]+[a-z]?\*\*' || true)

    if [ -n "$new_lines" ]; then
        # Build pipe-delimited list of IDs that are genuinely new (not in prior commit)
        new_ids=""
        while IFS= read -r line; do
            id=$(printf '%s' "$line" | grep -oE '[A-Z]+[0-9]+[a-z]?' | head -1)
            if [ -n "$id" ] && ! printf '%s\n' $prior_ids | grep -qx "$id"; then
                new_ids="${new_ids}|${id}"
            fi
        done <<DIFFEOF
$new_lines
DIFFEOF
        new_ids="${new_ids#|}"  # strip leading pipe

        if [ -n "$new_ids" ]; then
            # Stamp matching lines using awk (BSD-awk-compatible; pipe-delimited IDs)
            tmpfile=$(mktemp)
            awk -v ids="$new_ids" -v stamp="(added $today)" '
            BEGIN {
                n = split(ids, arr, "|")
                for (i = 1; i <= n; i++) {
                    if (arr[i] != "") id_set[arr[i]] = 1
                }
            }
            /^\- \[[ x]\] \*\*[A-Z]+[0-9]+[a-z]?\*\*/ {
                line = $0
                if (match(line, /\*\*[A-Z]+[0-9]+[a-z]?\*\*/)) {
                    id_raw = substr(line, RSTART, RLENGTH)
                    gsub(/\*/, "", id_raw)
                    already = (line ~ /\(added [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]\)$/)
                    if ((id_raw in id_set) && !already) {
                        print line " " stamp
                        next
                    }
                }
            }
            { print }
            ' TODO.md > "$tmpfile"
            mv "$tmpfile" TODO.md
        fi
    fi
    # --- End date-stamp ---

    python3 bin/sync-todo-index.py

    # --- F-item bucket tag gate ---
    # sync-todo-index.py groups F-items by bucket tag ([arch] / [hardening] /
    # [polish] / [testing] / [infra]). Items without one of those tags land
    # in `### F · Untagged`. Hard-fail the commit so the author tags them
    # before shipping. Build 23 shipped 7 untagged completed F-items because
    # this gate did not exist; never again.
    if grep -q '^### F · Untagged' TODO.md; then
        echo "pre-commit: TODO.md has F-items missing a bucket tag." >&2
        echo "" >&2
        echo "Each F-item must end its description with one of:" >&2
        echo "  [arch]  [hardening]  [polish]  [testing]  [infra]" >&2
        echo "" >&2
        echo "Untagged items currently in TODO.md:" >&2
        awk '
            /^### F · Untagged/ { flag = 1; next }
            /^### / { flag = 0 }
            flag && /^- \[/ {
                if (match($0, /\*\*[A-Z]+[0-9]+[a-z]?\*\*/)) {
                    id = substr($0, RSTART, RLENGTH)
                    gsub(/\*/, "", id)
                    print "  - " id
                }
            }
        ' TODO.md >&2
        echo "" >&2
        echo "Append the appropriate tag to each line, then commit again." >&2
        echo "(The hook re-runs sync-todo-index.py automatically.)" >&2
        exit 1
    fi
    # --- End F-item bucket tag gate ---

    # --- [next]-tag gate on completion commits ---
    # When a commit checks an item off (a newly-added top-level `- [x]`
    # line in the staged diff), the chain runner needs at least one
    # [next]-tagged unchecked item to pick up next. Build 23 shipped
    # completions without [next] tags; a follow-up commit (bd16521) had
    # to add them after the fact. Asymmetric on purpose — pure morning
    # fixes that don't check anything off are not gated.
    completed_ids=$(git diff --cached --unified=0 -- TODO.md \
        | grep '^+- \[x\]' \
        | grep -oE '\*\*[A-Z]+[0-9]+[a-z]?\*\*' \
        | tr -d '*' \
        | sort -u || true)

    if [ -n "$completed_ids" ]; then
        if ! grep -qE '^- \[ \].*\[next\]' TODO.md; then
            echo "pre-commit: this commit checks items off but TODO.md has no" >&2
            echo "[next]-tagged unchecked items left for the chain runner." >&2
            echo "" >&2
            echo "Items being checked off in this commit:" >&2
            printf '  - %s\n' $completed_ids >&2
            echo "" >&2
            echo "Tag at least one unchecked item with [next] (prefer prereqs of" >&2
            echo "in-progress work, then [easy] items), then commit again." >&2
            exit 1
        fi
    fi
    # --- End [next]-tag gate ---

    # Re-stage TODO.md if stamping or sync modified it
    if ! git diff --quiet TODO.md; then
        echo "pre-commit: re-staged TODO.md after date-stamp + sync-todo-index"
        git add TODO.md
    fi
fi
